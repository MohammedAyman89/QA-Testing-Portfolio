    {
      "name": "Create Board",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();",
              "pm.environment.set(\"boardId\", jsonData.id);",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response contains id\", function () {",
              "    pm.expect(jsonData.id).to.exist;",
              "    pm.expect(jsonData.id).to.be.ok;",
              "});",
              "",
              "pm.test(\"Response contains name\", function () {",
              "    pm.expect(jsonData.name).to.exist;",
              "    pm.expect(jsonData.name).to.be.ok;",
              "});",
              "",
              "pm.test(\"Response contains url\", function () {",
              "    pm.expect(jsonData.url).to.exist;",
              "    pm.expect(jsonData.url).to.be.ok;",
              "});",
              "",
              "",
              "",
              "let createboardname = pm.environment.get(\"myVar\");",
              "pm.test(\"correct board name\", function () {",
              "    pm.expect(jsonData.name).to.eql(createboardname);",
              "});",
              "",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
